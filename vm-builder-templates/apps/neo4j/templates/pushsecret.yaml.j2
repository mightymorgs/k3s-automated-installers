{#
  PushSecret: Neo4j auth credentials -> Vault KV

  Pushes the neo4j-auth K8s Secret to Vault KV at apps/data/neo4j/.
  NEO4J_AUTH format is "neo4j/password" — the full string is pushed.
  Requires ClusterSecretStore "vault-backend" with write access.

  Variables:
    - app_namespace: Kubernetes namespace (default: "neo4j")
#}
---
apiVersion: external-secrets.io/v1alpha1
kind: PushSecret
metadata:
  name: neo4j-push
  namespace: {{ app_namespace | default('neo4j') }}
  labels:
    app.kubernetes.io/name: neo4j
    app.kubernetes.io/component: push-secret
    app.kubernetes.io/part-of: golden-master
spec:
  secretStoreRefs:
    - name: vault-backend
      kind: ClusterSecretStore
  selector:
    secret:
      name: neo4j-auth
  data:
    - match:
        secretKey: NEO4J_AUTH
        remoteRef:
          remoteKey: apps/data/neo4j/admin_password
          property: value
