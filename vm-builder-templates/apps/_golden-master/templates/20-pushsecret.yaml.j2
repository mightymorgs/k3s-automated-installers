{#
  PushSecret: {{ app_name }} credentials → Vault KV
  Prefix 20 → always kubectl apply (never replace --force).

  Naming contract:
    PushSecret name: {{ app_name }}-push
    Source secret:   {{ app_name }}-credentials
    Vault path:      apps/data/{{ app_name }}/{{ bws_field }}
#}
---
apiVersion: external-secrets.io/v1alpha1
kind: PushSecret
metadata:
  name: {{ app_name }}-push
  namespace: {{ app_namespace }}
  labels:
    app.kubernetes.io/name: {{ app_name }}
    app.kubernetes.io/component: push-secret
    app.kubernetes.io/part-of: golden-master
spec:
  secretStoreRefs:
    - name: vault-backend
      kind: ClusterSecretStore
  selector:
    secret:
      name: {{ secret_name | default(app_name + '-credentials') }}
  data:
    {# One entry per credential field. Example: #}
    - match:
        secretKey: PLACEHOLDER_FIELD
        remoteRef:
          remoteKey: apps/data/{{ app_name }}/placeholder_field
          property: value
