{#
  StatefulSet for {{ app_name }}.
  Prefix 40 → uses kubectl {{ kubectl_action }}.
  Replace --force in full mode restarts pods (intended behaviour).

  If this StatefulSet has volumeClaimTemplates, the install playbook's
  PVC safety gate will downgrade to kubectl apply when existing PVCs are Bound.
#}
---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: {{ app_name }}
  namespace: {{ app_namespace }}
  labels:
    app.kubernetes.io/name: {{ app_name }}
    app.kubernetes.io/managed-by: idi-ansible
    app.kubernetes.io/part-of: golden-master
spec:
  serviceName: {{ app_name }}
  replicas: {{ replicas | default(1) }}
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ app_name }}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ app_name }}
    spec:
      containers:
        - name: {{ app_name }}
          image: {{ image | default('placeholder:latest') }}
          ports:
            - containerPort: {{ container_port | default(8080) }}
          resources:
            requests:
              cpu: {{ cpu_request | default('100m') }}
              memory: {{ memory_request | default('256Mi') }}
            limits:
              cpu: {{ cpu_limit | default('500m') }}
              memory: {{ memory_limit | default('512Mi') }}
          envFrom:
            - secretRef:
                name: {{ secret_name | default(app_name + '-credentials') }}
          volumeMounts:
            - name: data
              mountPath: /data
  volumeClaimTemplates:
    - metadata:
        name: data
        labels:
          app.kubernetes.io/name: {{ app_name }}
      spec:
        accessModes: ["ReadWriteOnce"]
        storageClassName: {{ storage_class | default('longhorn') }}
        resources:
          requests:
            storage: {{ storage_size | default('10Gi') }}
