{#
  K8s Secret for {{ app_name }}.
  Prefix 10 → always kubectl apply (never replace --force).

  All credentials in ONE aggregate secret for the credential pipeline:
  K8s Secret → PushSecret → Vault KV → sync-app-state.sh → BWS

  Naming contract: {{ app_name }}-credentials
  (override with secret_name var for operator-managed apps)
#}
---
apiVersion: v1
kind: Secret
metadata:
  name: {{ secret_name | default(app_name + '-credentials') }}
  namespace: {{ app_namespace }}
  labels:
    app.kubernetes.io/name: {{ app_name }}
    app.kubernetes.io/component: credentials
    app.kubernetes.io/managed-by: idi-ansible
    app.kubernetes.io/part-of: golden-master
type: Opaque
stringData:
  {# Add one field per credential. Example: #}
  {# ADMIN_PASSWORD: "{{ admin_password }}" #}
  {# API_KEY: "{{ api_key }}" #}
  PLACEHOLDER_FIELD: "{{ placeholder_value }}"
