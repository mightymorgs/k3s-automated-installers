{#
  PushSecret: Langfuse secrets -> Vault KV

  Pushes all langfuse credentials from langfuse-config K8s Secret to Vault KV
  at apps/data/langfuse/. All 3 credentials (nextauth_secret, salt,
  postgres_password) are in one secret for single-secret credential pipeline.
  Requires ClusterSecretStore "vault-backend" with write access.

  Variables:
    - app_namespace: Kubernetes namespace (default: "ai-tools")
#}
---
apiVersion: external-secrets.io/v1alpha1
kind: PushSecret
metadata:
  name: langfuse-push
  namespace: {{ app_namespace | default('ai-tools') }}
  labels:
    app.kubernetes.io/name: langfuse
    app.kubernetes.io/component: push-secret
    app.kubernetes.io/part-of: golden-master
spec:
  secretStoreRefs:
    - name: vault-backend
      kind: ClusterSecretStore
  selector:
    secret:
      name: langfuse-config
  data:
    - match:
        secretKey: NEXTAUTH_SECRET
        remoteRef:
          remoteKey: apps/data/langfuse/nextauth_secret
          property: value
    - match:
        secretKey: SALT
        remoteRef:
          remoteKey: apps/data/langfuse/salt
          property: value
    - match:
        secretKey: POSTGRES_PASSWORD
        remoteRef:
          remoteKey: apps/data/langfuse/postgres_password
          property: value
