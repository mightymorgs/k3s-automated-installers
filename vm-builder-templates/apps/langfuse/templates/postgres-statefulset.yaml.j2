---
# Langfuse PostgreSQL StatefulSet
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: {{ postgres_host | default('langfuse-postgres') }}
  namespace: {{ app_namespace | default('ai-tools') }}
  labels:
    app: {{ postgres_host | default('langfuse-postgres') }}
    app.kubernetes.io/name: {{ postgres_host | default('langfuse-postgres') }}
    app.kubernetes.io/part-of: {{ app_name | default('langfuse') }}
spec:
  serviceName: {{ postgres_host | default('langfuse-postgres') }}
  replicas: {{ postgres_replicas | default(1) }}
  selector:
    matchLabels:
      app: {{ postgres_host | default('langfuse-postgres') }}
  template:
    metadata:
      labels:
        app: {{ postgres_host | default('langfuse-postgres') }}
        app.kubernetes.io/name: {{ postgres_host | default('langfuse-postgres') }}
        app.kubernetes.io/part-of: {{ app_name | default('langfuse') }}
    spec:
      securityContext:
        fsGroup: 70
      initContainers:
        - name: init-pgdata
          image: {{ busybox_image | default('busybox:1.36') }}
          command: ['sh', '-c', 'mkdir -p /var/lib/postgresql/data/pgdata && chown -R 70:70 /var/lib/postgresql/data']
          volumeMounts:
            - name: postgres-data
              mountPath: /var/lib/postgresql/data
      containers:
        - name: postgres
          image: {{ postgres_image | default('postgres:15-alpine') }}
          ports:
            - name: postgres
              containerPort: {{ postgres_port | default(5432) }}
              protocol: TCP
          env:
            - name: POSTGRES_DB
              value: {{ postgres_db | default('langfuse') }}
            - name: POSTGRES_USER
              value: {{ postgres_user | default('langfuse') }}
            - name: POSTGRES_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: {{ postgres_secret_name | default('langfuse-postgres') }}
                  key: password
            - name: PGDATA
              value: /var/lib/postgresql/data/pgdata
          volumeMounts:
            - name: postgres-data
              mountPath: /var/lib/postgresql/data
          resources:
            requests:
              cpu: {{ postgres_cpu_request | default('100m') }}
              memory: {{ postgres_memory_request | default('256Mi') }}
            limits:
              cpu: {{ postgres_cpu_limit | default('500m') }}
              memory: {{ postgres_memory_limit | default('1Gi') }}
          livenessProbe:
            exec:
              command: ["pg_isready", "-U", "{{ postgres_user | default('langfuse') }}"]
            initialDelaySeconds: {{ postgres_liveness_initial_delay | default(30) }}
            periodSeconds: {{ postgres_liveness_period | default(10) }}
          readinessProbe:
            exec:
              command: ["pg_isready", "-U", "{{ postgres_user | default('langfuse') }}"]
            initialDelaySeconds: {{ postgres_readiness_initial_delay | default(5) }}
            periodSeconds: {{ postgres_readiness_period | default(5) }}
  volumeClaimTemplates:
    - metadata:
        name: postgres-data
        labels:
          app: {{ postgres_host | default('langfuse-postgres') }}
      spec:
        accessModes: ["ReadWriteOnce"]
        storageClassName: {{ storage_class | default('longhorn') }}
        resources:
          requests:
            storage: {{ postgres_storage_size | default('10Gi') }}
