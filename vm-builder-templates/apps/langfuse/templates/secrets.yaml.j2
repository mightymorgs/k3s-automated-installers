---
# Langfuse Secrets — postgres password, NextAuth secret, salt
# Values generated at deploy time; overridable via extra-vars
apiVersion: v1
kind: Secret
metadata:
  name: {{ postgres_secret_name | default('langfuse-postgres') }}
  namespace: {{ app_namespace | default('ai-tools') }}
  labels:
    app: {{ app_name | default('langfuse') }}
    app.kubernetes.io/name: {{ app_name | default('langfuse') }}
    app.kubernetes.io/component: database
type: Opaque
stringData:
  password: "{{ postgres_password }}"

---
# Langfuse application secrets (NextAuth + salt)
apiVersion: v1
kind: Secret
metadata:
  name: {{ config_secret_name | default('langfuse-config') }}
  namespace: {{ app_namespace | default('ai-tools') }}
  labels:
    app: {{ app_name | default('langfuse') }}
    app.kubernetes.io/name: {{ app_name | default('langfuse') }}
    app.kubernetes.io/component: server
type: Opaque
stringData:
  NEXTAUTH_SECRET: "{{ nextauth_secret }}"
  SALT: "{{ salt }}"
  POSTGRES_PASSWORD: "{{ postgres_password }}"
