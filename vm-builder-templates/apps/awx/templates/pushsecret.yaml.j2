{#
  PushSecret: AWX admin password -> Vault KV

  Pushes the awx-admin-password K8s Secret to Vault KV at apps/data/awx/.
  Requires ClusterSecretStore "vault-backend" with write access.

  Variables:
    - app_namespace: Kubernetes namespace (default: "awx")
#}
---
apiVersion: external-secrets.io/v1alpha1
kind: PushSecret
metadata:
  name: awx-push
  namespace: {{ app_namespace | default('awx') }}
  labels:
    app.kubernetes.io/name: awx
    app.kubernetes.io/component: push-secret
    app.kubernetes.io/part-of: golden-master
spec:
  secretStoreRefs:
    - name: vault-backend
      kind: ClusterSecretStore
  selector:
    secret:
      name: awx-admin-password
  data:
    - match:
        secretKey: password
        remoteRef:
          remoteKey: apps/data/awx/admin_password
          property: value
