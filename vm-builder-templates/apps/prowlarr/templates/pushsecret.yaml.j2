{#
  PushSecret: Prowlarr API key -> Vault KV

  Pushes the prowlarr-credentials K8s Secret to Vault KV at apps/data/prowlarr/.
  Requires ClusterSecretStore "vault-backend" with write access.

  Variables:
    - app_namespace: Kubernetes namespace (default: "media-stack")
#}
---
apiVersion: external-secrets.io/v1alpha1
kind: PushSecret
metadata:
  name: prowlarr-push
  namespace: {{ app_namespace | default('media-stack') }}
  labels:
    app.kubernetes.io/name: prowlarr
    app.kubernetes.io/component: push-secret
    app.kubernetes.io/part-of: golden-master
spec:
  secretStoreRefs:
    - name: vault-backend
      kind: ClusterSecretStore
  selector:
    secret:
      name: prowlarr-credentials
  data:
    - match:
        secretKey: api_key
        remoteRef:
          remoteKey: apps/data/prowlarr/api_key
          property: value
