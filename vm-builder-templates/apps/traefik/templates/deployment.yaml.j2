---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ app_name | default('traefik') }}
  namespace: {{ app_namespace | default('traefik') }}
  labels:
    app: {{ app_name | default('traefik') }}
    app.kubernetes.io/name: {{ app_name | default('traefik') }}
    app.kubernetes.io/instance: {{ app_name | default('traefik') }}
    app.kubernetes.io/managed-by: idi-phase5
spec:
  replicas: {{ traefik_replicas | default(1) }}
  selector:
    matchLabels:
      app: {{ app_name | default('traefik') }}
  template:
    metadata:
      labels:
        app: {{ app_name | default('traefik') }}
        app.kubernetes.io/name: {{ app_name | default('traefik') }}
    spec:
      serviceAccountName: {{ app_name | default('traefik') }}
      containers:
        - name: {{ app_name | default('traefik') }}
          image: {{ traefik_image | default('traefik:v3.3') }}
          args:
            - --api.dashboard=true
            - --api.insecure=false
            - --ping=true
            - --ping.entryPoint=web
            - --entryPoints.web.address=:{{ web_port | default(8000) }}
            - --entryPoints.websecure.address=:{{ websecure_port | default(8443) }}
            - --entryPoints.websecure.http.tls=true
            - --providers.kubernetescrd
            - --providers.kubernetescrd.allowCrossNamespace=true
            - --providers.kubernetesingress
            - --log.level={{ log_level | default('INFO') }}
            - --accesslog=true
          ports:
            - name: web
              containerPort: {{ web_port | default(8000) }}
              protocol: TCP
            - name: websecure
              containerPort: {{ websecure_port | default(8443) }}
              protocol: TCP
          livenessProbe:
            httpGet:
              path: /ping
              port: web
            initialDelaySeconds: {{ liveness_initial_delay | default(10) }}
            periodSeconds: {{ liveness_period | default(10) }}
          readinessProbe:
            httpGet:
              path: /ping
              port: web
            initialDelaySeconds: {{ readiness_initial_delay | default(5) }}
            periodSeconds: {{ readiness_period | default(5) }}
          resources:
            requests:
              cpu: {{ traefik_cpu_request | default('100m') }}
              memory: {{ traefik_memory_request | default('128Mi') }}
            limits:
              cpu: {{ traefik_cpu_limit | default('1000m') }}
              memory: {{ traefik_memory_limit | default('512Mi') }}
          securityContext:
            readOnlyRootFilesystem: true
            runAsNonRoot: true
            runAsUser: {{ run_as_user | default(65532) }}
            capabilities:
              drop: ["ALL"]
              add: ["NET_BIND_SERVICE"]
