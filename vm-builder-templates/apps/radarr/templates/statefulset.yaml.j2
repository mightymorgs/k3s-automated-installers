---
# Radarr StatefulSet (J2 template)
# Defaults match k8s-standalone/base/statefulset.yaml
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: {{ app_name | default('radarr') }}
  namespace: {{ app_namespace | default('media-stack') }}
  labels:
    app: {{ app_name | default('radarr') }}
    app.kubernetes.io/name: {{ app_name | default('radarr') }}
    app.kubernetes.io/component: pvr
    app.kubernetes.io/part-of: media-stack
spec:
  serviceName: {{ app_name | default('radarr') }}
  replicas: {{ replicas | default(1) }}
  selector:
    matchLabels:
      app: {{ app_name | default('radarr') }}
  template:
    metadata:
      labels:
        app: {{ app_name | default('radarr') }}
        app.kubernetes.io/name: {{ app_name | default('radarr') }}
    spec:
      containers:
        - name: {{ app_name | default('radarr') }}
          image: {{ image | default('lscr.io/linuxserver/radarr:latest') }}
          imagePullPolicy: {{ image_pull_policy | default('IfNotPresent') }}
          env:
            - name: PUID
              value: "{{ puid | default('1000') }}"
            - name: PGID
              value: "{{ pgid | default('1000') }}"
            - name: TZ
              value: "{{ timezone | default('Australia/Sydney') }}"
          ports:
            - name: http
              containerPort: {{ container_port | default(7878) }}
              protocol: TCP
          volumeMounts:
            - name: config
              mountPath: /config
            - name: shared-media
              mountPath: {{ media_mount_path | default('/media') }}
              subPath: {{ media_subpath | default('media') }}
            - name: shared-media
              mountPath: {{ downloads_mount_path | default('/downloads') }}
              subPath: {{ downloads_subpath | default('downloads') }}
          resources:
            requests:
              cpu: {{ cpu_request | default('200m') }}
              memory: {{ memory_request | default('512Mi') }}
            limits:
              cpu: {{ cpu_limit | default('1000m') }}
              memory: {{ memory_limit | default('1Gi') }}
          livenessProbe:
            httpGet:
              path: {{ health_path | default('/ping') }}
              port: http
            initialDelaySeconds: {{ liveness_initial_delay | default(60) }}
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 3
          readinessProbe:
            httpGet:
              path: {{ health_path | default('/ping') }}
              port: http
            initialDelaySeconds: {{ readiness_initial_delay | default(30) }}
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 3
      volumes:
        - name: shared-media
          persistentVolumeClaim:
            claimName: {{ media_pvc_name | default('media-shared-pvc') }}
  volumeClaimTemplates:
    - metadata:
        name: config
        labels:
          app: {{ app_name | default('radarr') }}
      spec:
        accessModes: ["ReadWriteOnce"]
        storageClassName: {{ storage_class | default('longhorn') }}
        resources:
          requests:
            storage: {{ config_storage_size | default('1Gi') }}
