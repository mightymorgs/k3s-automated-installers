{#
  PushSecret: ArgoCD initial admin password -> Vault KV

  Pushes the argocd-initial-admin-secret K8s Secret to Vault KV at
  apps/data/argocd/. Requires ClusterSecretStore "vault-backend" with
  write access.

  Variables:
    - app_namespace: Kubernetes namespace (default: "argocd")
#}
---
apiVersion: external-secrets.io/v1alpha1
kind: PushSecret
metadata:
  name: argocd-push
  namespace: {{ app_namespace | default('argocd') }}
  labels:
    app.kubernetes.io/name: argocd
    app.kubernetes.io/component: push-secret
    app.kubernetes.io/part-of: golden-master
spec:
  secretStoreRefs:
    - name: vault-backend
      kind: ClusterSecretStore
  selector:
    secret:
      name: argocd-initial-admin-secret
  data:
    - match:
        secretKey: password
        remoteRef:
          remoteKey: apps/data/argocd/admin_password
          property: value
