---
# ArgoCD Service (J2 template)
# Defaults match k8s-base/service.yaml
apiVersion: v1
kind: Service
metadata:
  name: {{ app_name | default('argocd') }}
  namespace: {{ app_namespace | default('argocd') }}
  labels:
    app.kubernetes.io/name: {{ app_name | default('argocd') }}
spec:
  type: {{ service_type | default('NodePort') }}
  selector:
    app.kubernetes.io/name: {{ app_name | default('argocd') }}
  ports:
    - name: http
      port: {{ service_port | default(8080) }}
      targetPort: http
{% if service_type | default('NodePort') == 'NodePort' %}
      nodePort: {{ nodeport | default(30444) }}
{% endif %}
      protocol: TCP
