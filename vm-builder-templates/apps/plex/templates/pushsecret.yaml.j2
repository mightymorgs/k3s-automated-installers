{#
  PushSecret: Plex API key -> Vault KV

  Pushes the plex-credentials K8s Secret to Vault KV at apps/data/plex/.
  Requires ClusterSecretStore "vault-backend" with write access.

  Variables:
    - app_namespace: Kubernetes namespace (default: "plex")
#}
---
apiVersion: external-secrets.io/v1alpha1
kind: PushSecret
metadata:
  name: plex-push
  namespace: {{ app_namespace | default('plex') }}
  labels:
    app.kubernetes.io/name: plex
    app.kubernetes.io/component: push-secret
    app.kubernetes.io/part-of: golden-master
spec:
  secretStoreRefs:
    - name: vault-backend
      kind: ClusterSecretStore
  selector:
    secret:
      name: plex-credentials
  data:
    - match:
        secretKey: api_key
        remoteRef:
          remoteKey: apps/data/plex/api_key
          property: value
