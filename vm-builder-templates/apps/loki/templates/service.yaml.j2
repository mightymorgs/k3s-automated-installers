---
# Loki Service (J2 template)
# Defaults match k8s-base/service.yaml
apiVersion: v1
kind: Service
metadata:
  name: {{ app_name | default('loki') }}
  namespace: {{ app_namespace | default('observability') }}
  labels:
    app: {{ app_name | default('loki') }}
    app.kubernetes.io/name: {{ app_name | default('loki') }}
    app.kubernetes.io/part-of: observability
spec:
  type: {{ service_type | default('NodePort') }}
  selector:
    app: {{ app_name | default('loki') }}
  ports:
    - name: http
      port: {{ container_port | default(3100) }}
      targetPort: {{ container_port | default(3100) }}
{% if service_type | default('NodePort') == 'NodePort' %}
      nodePort: {{ nodeport | default(30310) }}
{% endif %}
      protocol: TCP
