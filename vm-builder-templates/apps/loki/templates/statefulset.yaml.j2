---
# Loki StatefulSet (J2 template)
# Defaults match k8s-base/statefulset.yaml
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: {{ app_name | default('loki') }}
  namespace: {{ app_namespace | default('observability') }}
  labels:
    app: {{ app_name | default('loki') }}
    app.kubernetes.io/name: {{ app_name | default('loki') }}
    app.kubernetes.io/part-of: observability
spec:
  serviceName: {{ app_name | default('loki') }}
  replicas: {{ replicas | default(1) }}
  selector:
    matchLabels:
      app: {{ app_name | default('loki') }}
  template:
    metadata:
      labels:
        app: {{ app_name | default('loki') }}
        app.kubernetes.io/name: {{ app_name | default('loki') }}
    spec:
      securityContext:
        fsGroup: {{ fs_group | default(10001) }}
        runAsUser: {{ run_as_user | default(10001) }}
        runAsGroup: {{ run_as_group | default(10001) }}
      containers:
        - name: {{ app_name | default('loki') }}
          image: {{ image | default('grafana/loki:3.3.2') }}
          args:
            - -config.file={{ config_file | default('/etc/loki/loki.yaml') }}
          ports:
            - name: http
              containerPort: {{ container_port | default(3100) }}
              protocol: TCP
          volumeMounts:
            - name: config
              mountPath: {{ config_mount_path | default('/etc/loki') }}
            - name: data
              mountPath: {{ data_mount_path | default('/loki') }}
          resources:
            requests:
              cpu: {{ cpu_request | default('250m') }}
              memory: {{ memory_request | default('512Mi') }}
            limits:
              cpu: {{ cpu_limit | default('1000m') }}
              memory: {{ memory_limit | default('2Gi') }}
          readinessProbe:
            httpGet:
              path: {{ ready_path | default('/ready') }}
              port: {{ container_port | default(3100) }}
            initialDelaySeconds: {{ readiness_initial_delay | default(15) }}
            periodSeconds: {{ readiness_period | default(10) }}
          livenessProbe:
            httpGet:
              path: {{ liveness_path | default('/ready') }}
              port: {{ container_port | default(3100) }}
            initialDelaySeconds: {{ liveness_initial_delay | default(30) }}
            periodSeconds: {{ liveness_period | default(30) }}
      volumes:
        - name: config
          configMap:
            name: {{ configmap_name | default('loki-config') }}
  volumeClaimTemplates:
    - metadata:
        name: data
        labels:
          app: {{ app_name | default('loki') }}
      spec:
        accessModes: ["ReadWriteOnce"]
        storageClassName: {{ storage_class | default('longhorn-single') }}
        resources:
          requests:
            storage: {{ data_storage_size | default('10Gi') }}
