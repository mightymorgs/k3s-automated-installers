---
# Kibana Deployment (J2 template)
# Defaults match k8s-base/deployment.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ app_name | default('kibana') }}
  namespace: {{ app_namespace | default('kibana') }}
  labels:
    app.kubernetes.io/name: {{ app_name | default('kibana') }}
    app.kubernetes.io/component: server
spec:
  replicas: {{ replicas | default(1) }}
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ app_name | default('kibana') }}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{ app_name | default('kibana') }}
        app.kubernetes.io/component: server
    spec:
      containers:
        - name: {{ app_name | default('kibana') }}
          image: {{ image | default('docker.elastic.co/kibana/kibana:8.16.1') }}
          imagePullPolicy: {{ image_pull_policy | default('IfNotPresent') }}
          ports:
            - name: http
              containerPort: {{ container_port | default(5601) }}
              protocol: TCP
          env:
            - name: ELASTICSEARCH_HOSTS
              value: {{ elasticsearch_hosts | default('http://elasticsearch.elastic.svc:9200') }}
            - name: SERVER_NAME
              value: {{ server_name | default('kibana') }}
            - name: SERVER_HOST
              value: "{{ server_host | default('0.0.0.0') }}"
          envFrom:
            - secretRef:
                name: {{ secret_name | default('kibana-secrets') }}
                optional: true
          resources:
            requests:
              cpu: {{ cpu_request | default('100m') }}
              memory: {{ memory_request | default('256Mi') }}
            limits:
              cpu: {{ cpu_limit | default('1000m') }}
              memory: {{ memory_limit | default('1Gi') }}
          readinessProbe:
            httpGet:
              path: {{ health_path | default('/api/status') }}
              port: http
            initialDelaySeconds: {{ readiness_initial_delay | default(60) }}
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 10
          livenessProbe:
            httpGet:
              path: {{ health_path | default('/api/status') }}
              port: http
            initialDelaySeconds: {{ liveness_initial_delay | default(180) }}
            periodSeconds: 15
            timeoutSeconds: 5
            failureThreshold: 10
