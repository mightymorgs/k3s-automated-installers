---
# Kibana ConfigMap (J2 template)
# Defaults match k8s-base/configmap.yaml
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ configmap_name | default('kibana-config') }}
  namespace: {{ app_namespace | default('kibana') }}
  labels:
    app.kubernetes.io/name: {{ app_name | default('kibana') }}
data:
  # Configuration will be populated by ansible
  APP_URL: "{{ app_url | default('http://localhost:' ~ (nodeport | default(30560)) | string) }}"
