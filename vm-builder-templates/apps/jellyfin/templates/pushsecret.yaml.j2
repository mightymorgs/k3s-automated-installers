{#
  PushSecret: Jellyfin API key -> Vault KV

  Pushes the jellyfin-credentials K8s Secret to Vault KV at apps/data/jellyfin/.
  Best-effort: API key may not exist until Jellyfin is configured via UI.
  Requires ClusterSecretStore "vault-backend" with write access.

  Variables:
    - app_namespace: Kubernetes namespace (default: "jellyfin")
#}
---
apiVersion: external-secrets.io/v1alpha1
kind: PushSecret
metadata:
  name: jellyfin-push
  namespace: {{ app_namespace | default('jellyfin') }}
  labels:
    app.kubernetes.io/name: jellyfin
    app.kubernetes.io/component: push-secret
    app.kubernetes.io/part-of: golden-master
spec:
  secretStoreRefs:
    - name: vault-backend
      kind: ClusterSecretStore
  selector:
    secret:
      name: jellyfin-credentials
  data:
    - match:
        secretKey: api_key
        remoteRef:
          remoteKey: apps/data/jellyfin/api_key
          property: value
