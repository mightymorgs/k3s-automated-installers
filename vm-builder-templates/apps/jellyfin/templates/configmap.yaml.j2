---
# Jellyfin ConfigMap (J2 template)
# Defaults match k8s-base/configmap.yaml
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ configmap_name | default('jellyfin-config') }}
  namespace: {{ app_namespace | default('jellyfin') }}
  labels:
    app.kubernetes.io/name: {{ app_name | default('jellyfin') }}
data:
  APP_URL: "{{ app_url | default('http://localhost:' ~ (nodeport | default(30096)) | string) }}"
