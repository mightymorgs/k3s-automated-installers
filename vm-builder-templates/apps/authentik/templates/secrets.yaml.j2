---
# Authentik Secrets
# Values should be pre-populated via ESO or manually before deploy
apiVersion: v1
kind: Secret
metadata:
  name: {{ secrets_name | default('authentik-secrets') }}
  namespace: {{ app_namespace | default('authentik') }}
  labels:
    app: {{ app_name | default('authentik') }}
    app.kubernetes.io/name: {{ app_name | default('authentik') }}
    app.kubernetes.io/managed-by: idi-phase5
type: Opaque
stringData:
  secret-key: "{{ authentik_secret_key }}"
  postgres-password: "{{ authentik_postgres_password }}"
  bootstrap-password: "{{ authentik_bootstrap_password }}"
  bootstrap-email: "{{ bootstrap_email }}"
