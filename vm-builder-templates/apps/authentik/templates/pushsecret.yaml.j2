{#
  PushSecret: Authentik secrets -> Vault KV

  Pushes the authentik-secrets K8s Secret to Vault KV at
  apps/data/authentik/. Multi-key: secret_key, postgres_password,
  bootstrap_password. Requires ClusterSecretStore "vault-backend"
  with write access.

  Variables:
    - app_namespace: Kubernetes namespace (default: "authentik")
#}
---
apiVersion: external-secrets.io/v1alpha1
kind: PushSecret
metadata:
  name: authentik-push
  namespace: {{ app_namespace | default('authentik') }}
  labels:
    app.kubernetes.io/name: authentik
    app.kubernetes.io/component: push-secret
    app.kubernetes.io/part-of: golden-master
spec:
  secretStoreRefs:
    - name: vault-backend
      kind: ClusterSecretStore
  selector:
    secret:
      name: authentik-secrets
  data:
    - match:
        secretKey: secret-key
        remoteRef:
          remoteKey: apps/data/authentik/secret_key
          property: value
    - match:
        secretKey: postgres-password
        remoteRef:
          remoteKey: apps/data/authentik/postgres_password
          property: value
    - match:
        secretKey: bootstrap-password
        remoteRef:
          remoteKey: apps/data/authentik/bootstrap_password
          property: value
