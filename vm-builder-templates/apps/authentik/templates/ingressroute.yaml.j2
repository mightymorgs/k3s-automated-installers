---
# Authentik IngressRoute (no ForwardAuth on auth itself)
apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: {{ app_name | default('authentik') }}-ingressroute
  namespace: {{ app_namespace | default('authentik') }}
  labels:
    app: {{ app_name | default('authentik') }}
    app.kubernetes.io/name: {{ app_name | default('authentik') }}
    app.kubernetes.io/managed-by: idi-phase5
spec:
  entryPoints:
    - websecure
  routes:
    - match: Host(`{{ auth_hostname | default('auth') }}.{{ domain }}`)
      kind: Rule
      services:
        - name: {{ app_name | default('authentik') }}
          port: {{ http_port | default(9000) }}
  tls: {}
