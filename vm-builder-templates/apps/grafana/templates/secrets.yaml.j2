---
# Grafana Secrets (J2 template)
# Admin password auto-generated if not provided
apiVersion: v1
kind: Secret
metadata:
  name: {{ secret_name | default('grafana-secrets') }}
  namespace: {{ app_namespace | default('grafana') }}
  labels:
    app: {{ app_name | default('grafana') }}
    app.kubernetes.io/name: {{ app_name | default('grafana') }}
    app.kubernetes.io/managed-by: idi-ansible
type: Opaque
stringData:
  GF_SECURITY_ADMIN_USER: "{{ admin_user | default('admin') }}"
  GF_SECURITY_ADMIN_PASSWORD: "{{ admin_password }}"
