{#
  PushSecret: Grafana admin password -> Vault KV

  Pushes the grafana-secrets K8s Secret to Vault KV at apps/data/grafana/.
  Requires ClusterSecretStore "vault-backend" with write access.

  Variables:
    - app_namespace: Kubernetes namespace (default: "grafana")
#}
---
apiVersion: external-secrets.io/v1alpha1
kind: PushSecret
metadata:
  name: grafana-push
  namespace: {{ app_namespace | default('grafana') }}
  labels:
    app.kubernetes.io/name: grafana
    app.kubernetes.io/component: push-secret
    app.kubernetes.io/part-of: golden-master
spec:
  secretStoreRefs:
    - name: vault-backend
      kind: ClusterSecretStore
  selector:
    secret:
      name: grafana-secrets
  data:
    - match:
        secretKey: GF_SECURITY_ADMIN_PASSWORD
        remoteRef:
          remoteKey: apps/data/grafana/admin_password
          property: value
