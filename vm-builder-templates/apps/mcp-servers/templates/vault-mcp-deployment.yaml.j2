---
# Vault MCP Server Deployment (J2 template)
# Defaults match k8s-base/vault-mcp-deployment.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: vault-mcp
  namespace: {{ mcp_namespace | default('mcp-servers') }}
  labels:
    app.kubernetes.io/name: vault-mcp
    app.kubernetes.io/component: ai-operations
    app.kubernetes.io/part-of: golden-master
spec:
  replicas: {{ vault_mcp_replicas | default(1) }}
  selector:
    matchLabels:
      app.kubernetes.io/name: vault-mcp
      app.kubernetes.io/component: ai-operations
  template:
    metadata:
      labels:
        app.kubernetes.io/name: vault-mcp
        app.kubernetes.io/component: ai-operations
        app.kubernetes.io/part-of: golden-master
    spec:
      containers:
        - name: vault-mcp
          image: {{ vault_mcp_image | default('ghcr.io/mightymorgs/vault-mcp:latest') }}
          imagePullPolicy: {{ vault_mcp_image_pull_policy | default('Always') }}
          env:
            - name: VAULT_ADDR
              value: "{{ vault_mcp_vault_addr }}"
            - name: VAULT_TOKEN
              valueFrom:
                secretKeyRef:
                  name: {{ vault_mcp_secret_name | default('vault-mcp-credentials') }}
                  key: token
          ports:
            - name: http
              containerPort: {{ vault_mcp_port | default(8080) }}
              protocol: TCP
          resources:
            requests:
              memory: {{ vault_mcp_memory_request | default('128Mi') }}
              cpu: {{ vault_mcp_cpu_request | default('100m') }}
            limits:
              memory: {{ vault_mcp_memory_limit | default('256Mi') }}
              cpu: {{ vault_mcp_cpu_limit | default('500m') }}
          livenessProbe:
            httpGet:
              path: /health
              port: {{ vault_mcp_port | default(8080) }}
            initialDelaySeconds: {{ vault_mcp_liveness_initial_delay | default(10) }}
            periodSeconds: 30
          readinessProbe:
            httpGet:
              path: /health
              port: {{ vault_mcp_port | default(8080) }}
            initialDelaySeconds: {{ vault_mcp_readiness_initial_delay | default(5) }}
            periodSeconds: 10
