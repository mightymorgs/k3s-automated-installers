---
# K8s RAG MCP Server Service (J2 template)
# Defaults match k8s-base/k8s-rag-mcp-service.yaml
apiVersion: v1
kind: Service
metadata:
  name: k8s-rag-mcp
  namespace: {{ mcp_namespace | default('mcp-servers') }}
  labels:
    app.kubernetes.io/name: k8s-rag-mcp
    app.kubernetes.io/component: ai-operations
spec:
  type: {{ k8s_rag_mcp_service_type | default('ClusterIP') }}
  selector:
    app.kubernetes.io/name: k8s-rag-mcp
    app.kubernetes.io/component: ai-operations
  ports:
    - name: http
      port: {{ k8s_rag_mcp_port | default(8080) }}
      targetPort: http
{% if k8s_rag_mcp_service_type | default('ClusterIP') == 'NodePort' %}
      nodePort: {{ k8s_rag_mcp_nodeport | default(30183) }}
{% endif %}
      protocol: TCP
