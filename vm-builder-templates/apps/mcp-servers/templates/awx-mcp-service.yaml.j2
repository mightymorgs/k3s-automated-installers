---
# AWX MCP Server Service (J2 template)
# Defaults match k8s-base/awx-mcp-service.yaml
apiVersion: v1
kind: Service
metadata:
  name: awx-mcp
  namespace: {{ mcp_namespace | default('mcp-servers') }}
  labels:
    app.kubernetes.io/name: awx-mcp
    app.kubernetes.io/component: ai-operations
spec:
  type: {{ awx_mcp_service_type | default('ClusterIP') }}
  selector:
    app.kubernetes.io/name: awx-mcp
    app.kubernetes.io/component: ai-operations
  ports:
    - name: http
      port: {{ awx_mcp_port | default(8080) }}
      targetPort: http
{% if awx_mcp_service_type | default('ClusterIP') == 'NodePort' %}
      nodePort: {{ awx_mcp_nodeport | default(30181) }}
{% endif %}
      protocol: TCP
