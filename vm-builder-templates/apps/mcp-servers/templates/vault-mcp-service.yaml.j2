---
# Vault MCP Server Service (J2 template)
# Defaults match k8s-base/vault-mcp-service.yaml
apiVersion: v1
kind: Service
metadata:
  name: vault-mcp
  namespace: {{ mcp_namespace | default('mcp-servers') }}
  labels:
    app.kubernetes.io/name: vault-mcp
    app.kubernetes.io/component: ai-operations
spec:
  type: {{ vault_mcp_service_type | default('ClusterIP') }}
  selector:
    app.kubernetes.io/name: vault-mcp
    app.kubernetes.io/component: ai-operations
  ports:
    - name: http
      port: {{ vault_mcp_port | default(8080) }}
      targetPort: http
{% if vault_mcp_service_type | default('ClusterIP') == 'NodePort' %}
      nodePort: {{ vault_mcp_nodeport | default(30180) }}
{% endif %}
      protocol: TCP
