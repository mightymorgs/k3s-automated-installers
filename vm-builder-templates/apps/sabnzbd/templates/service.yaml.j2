---
# SABnzbd Service (J2 template)
# Defaults match k8s-standalone/base/service.yaml
apiVersion: v1
kind: Service
metadata:
  name: {{ app_name | default('sabnzbd') }}
  namespace: {{ app_namespace | default('media-stack') }}
  labels:
    app: {{ app_name | default('sabnzbd') }}
    app.kubernetes.io/name: {{ app_name | default('sabnzbd') }}
    app.kubernetes.io/part-of: media-stack
spec:
  type: {{ service_type | default('NodePort') }}
  selector:
    app: {{ app_name | default('sabnzbd') }}
  ports:
    - name: http
      port: {{ container_port | default(8080) }}
      targetPort: {{ container_port | default(8080) }}
{% if service_type | default('NodePort') == 'NodePort' %}
      nodePort: {{ nodeport | default(30870) }}
{% endif %}
      protocol: TCP
