---
# Kibana Deployment (J2 template)
# Defaults match k8s-base/kibana-deployment.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: kibana
  namespace: {{ app_namespace | default('elastic') }}
  labels:
    app: kibana
    app.kubernetes.io/name: kibana
    app.kubernetes.io/component: {{ app_component | default('observability') }}
    app.kubernetes.io/part-of: {{ app_part_of | default('golden-master') }}
spec:
  replicas: {{ kibana_replicas | default(1) }}
  selector:
    matchLabels:
      app: kibana
      app.kubernetes.io/name: kibana
  template:
    metadata:
      labels:
        app: kibana
        app.kubernetes.io/name: kibana
        app.kubernetes.io/component: {{ app_component | default('observability') }}
        app.kubernetes.io/part-of: {{ app_part_of | default('golden-master') }}
    spec:
      containers:
        - name: kibana
          image: {{ kibana_image | default('docker.elastic.co/kibana/kibana:8.16.1') }}
          imagePullPolicy: {{ image_pull_policy | default('IfNotPresent') }}
          env:
            - name: ELASTICSEARCH_HOSTS
              value: '["http://elasticsearch.{{ app_namespace | default("elastic") }}.svc.cluster.local:{{ container_port | default(9200) }}"]'
            - name: SERVER_NAME
              value: "{{ kibana_server_name | default('kibana') }}"
            - name: SERVER_HOST
              value: "{{ kibana_server_host | default('0.0.0.0') }}"
          ports:
            - name: http
              containerPort: {{ kibana_port | default(5601) }}
              protocol: TCP
          resources:
            requests:
              cpu: {{ kibana_cpu_request | default('250m') }}
              memory: {{ kibana_memory_request | default('512Mi') }}
            limits:
              cpu: {{ kibana_cpu_limit | default('1000m') }}
              memory: {{ kibana_memory_limit | default('1Gi') }}
          livenessProbe:
            httpGet:
              path: {{ kibana_health_path | default('/api/status') }}
              port: {{ kibana_port | default(5601) }}
            initialDelaySeconds: {{ kibana_liveness_initial_delay | default(60) }}
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 5
          readinessProbe:
            httpGet:
              path: {{ kibana_health_path | default('/api/status') }}
              port: {{ kibana_port | default(5601) }}
            initialDelaySeconds: {{ kibana_readiness_initial_delay | default(30) }}
            periodSeconds: 5
            timeoutSeconds: 3
            failureThreshold: 3
