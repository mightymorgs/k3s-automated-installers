---
# Elastic StatefulSet (J2 template)
# Defaults match k8s-base/elasticsearch-statefulset.yaml
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: {{ app_name | default('elastic') }}
  namespace: {{ app_namespace | default('elastic') }}
  labels:
    app: {{ app_name | default('elastic') }}
    app.kubernetes.io/name: {{ app_name | default('elastic') }}
    app.kubernetes.io/component: {{ app_component | default('server') }}
    app.kubernetes.io/part-of: {{ app_part_of | default('golden-master') }}
spec:
  serviceName: {{ app_name | default('elastic') }}
  replicas: {{ replicas | default(1) }}
  selector:
    matchLabels:
      app: {{ app_name | default('elastic') }}
      app.kubernetes.io/name: {{ app_name | default('elastic') }}
  template:
    metadata:
      labels:
        app: {{ app_name | default('elastic') }}
        app.kubernetes.io/name: {{ app_name | default('elastic') }}
        app.kubernetes.io/component: {{ app_component | default('server') }}
        app.kubernetes.io/part-of: {{ app_part_of | default('golden-master') }}
    spec:
      securityContext:
        fsGroup: {{ fs_group | default(1000) }}
        runAsUser: {{ run_as_user | default(1000) }}
        runAsNonRoot: true
      initContainers:
        - name: fix-permissions
          image: {{ init_image | default('busybox:1.36') }}
          command: ["sh", "-c", "chown -R {{ run_as_user | default(1000) }}:{{ fs_group | default(1000) }} {{ data_mount_path | default('/usr/share/elasticsearch/data') }}"]
          securityContext:
            runAsUser: 0
            runAsNonRoot: false
          volumeMounts:
            - name: data
              mountPath: {{ data_mount_path | default('/usr/share/elasticsearch/data') }}
      containers:
        - name: {{ app_name | default('elastic') }}
          image: {{ image | default('docker.elastic.co/elasticsearch/elasticsearch:8.16.1') }}
          imagePullPolicy: {{ image_pull_policy | default('IfNotPresent') }}
          env:
            - name: discovery.type
              value: "{{ discovery_type | default('single-node') }}"
            - name: xpack.security.enabled
              value: "{{ xpack_security_enabled | default('false') }}"
            - name: ES_JAVA_OPTS
              value: "{{ java_opts | default('-Xms512m -Xmx512m') }}"
            - name: cluster.name
              value: "{{ cluster_name | default('golden-master') }}"
            - name: node.name
              valueFrom:
                fieldRef:
                  fieldPath: metadata.name
          envFrom:
            - configMapRef:
                name: {{ configmap_name | default('elastic-config') }}
            - secretRef:
                name: {{ secret_name | default('elastic-secrets') }}
                optional: true
          ports:
            - name: http
              containerPort: {{ container_port | default(9200) }}
              protocol: TCP
            - name: transport
              containerPort: {{ transport_port | default(9300) }}
              protocol: TCP
          volumeMounts:
            - name: data
              mountPath: {{ data_mount_path | default('/usr/share/elasticsearch/data') }}
          resources:
            requests:
              cpu: {{ cpu_request | default('500m') }}
              memory: {{ memory_request | default('1Gi') }}
            limits:
              cpu: {{ cpu_limit | default('2000m') }}
              memory: {{ memory_limit | default('2Gi') }}
          livenessProbe:
            httpGet:
              path: {{ health_path | default('/_cluster/health') }}
              port: http
            initialDelaySeconds: {{ liveness_initial_delay | default(60) }}
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 5
          readinessProbe:
            httpGet:
              path: {{ health_path | default('/_cluster/health') }}
              port: http
            initialDelaySeconds: {{ readiness_initial_delay | default(30) }}
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 3
  volumeClaimTemplates:
    - metadata:
        name: data
        labels:
          app: {{ app_name | default('elastic') }}
          app.kubernetes.io/name: {{ app_name | default('elastic') }}
      spec:
        accessModes: ["ReadWriteOnce"]
        storageClassName: {{ storage_class | default('longhorn') }}
        resources:
          requests:
            storage: {{ data_storage_size | default('10Gi') }}
