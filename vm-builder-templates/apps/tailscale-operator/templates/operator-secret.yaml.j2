---
# Tailscale Operator OAuth Secret (J2 template)
# OAuth credentials are injected by the install playbook from BWS
apiVersion: v1
kind: Secret
metadata:
  name: {{ tailscale_operator_secret_name | default('operator-oauth') }}
  namespace: {{ tailscale_namespace | default('tailscale') }}
  labels:
    app.kubernetes.io/name: tailscale-operator
type: Opaque
stringData:
  client_id: "{{ tailscale_oauth_client_id }}"
  client_secret: "{{ tailscale_oauth_client_secret }}"
