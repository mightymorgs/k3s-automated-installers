{#
  External Secrets Operator — Webhook Service

  Variables:
    - app_namespace: Kubernetes namespace (default: "external-secrets")
    - webhook_port: Webhook container target port (default: 10250)
#}
---
apiVersion: v1
kind: Service
metadata:
  name: external-secrets-webhook
  namespace: {{ app_namespace | default('external-secrets') }}
  labels:
    app.kubernetes.io/name: external-secrets-webhook
    app.kubernetes.io/instance: external-secrets
    app.kubernetes.io/version: {{ eso_version | default('v0.9.13') | quote }}
    app.kubernetes.io/component: webhook
    app.kubernetes.io/part-of: golden-master
    external-secrets.io/component: webhook
spec:
  type: ClusterIP
  ports:
  - port: 443
    targetPort: {{ webhook_port | default(10250) }}
    protocol: TCP
    name: webhook
  selector:
    app.kubernetes.io/name: external-secrets-webhook
    app.kubernetes.io/instance: external-secrets
