{#
  External Secrets Operator — Controller Deployment

  Generated from helm template external-secrets v0.9.13, parameterized.

  Variables:
    - eso_version: ESO container image tag (default: "v0.9.13")
    - eso_replicas: Number of replicas (default: 1)
    - app_namespace: Kubernetes namespace (default: "external-secrets")
    - eso_concurrent: Concurrent reconciliation workers (default: 1)
    - eso_metrics_port: Metrics endpoint port (default: 8080)
    - eso_cpu_requests: CPU request (default: "100m")
    - eso_cpu_limits: CPU limit (default: "200m")
    - eso_memory_requests: Memory request (default: "128Mi")
    - eso_memory_limits: Memory limit (default: "256Mi")
#}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: external-secrets
  namespace: {{ app_namespace | default('external-secrets') }}
  labels:
    app.kubernetes.io/name: external-secrets
    app.kubernetes.io/instance: external-secrets
    app.kubernetes.io/version: {{ eso_version | default('v0.9.13') | quote }}
    app.kubernetes.io/component: controller
    app.kubernetes.io/part-of: golden-master
spec:
  replicas: {{ eso_replicas | default(1) }}
  revisionHistoryLimit: 10
  selector:
    matchLabels:
      app.kubernetes.io/name: external-secrets
      app.kubernetes.io/instance: external-secrets
  template:
    metadata:
      labels:
        app.kubernetes.io/name: external-secrets
        app.kubernetes.io/instance: external-secrets
        app.kubernetes.io/version: {{ eso_version | default('v0.9.13') | quote }}
        app.kubernetes.io/component: controller
        app.kubernetes.io/part-of: golden-master
    spec:
      serviceAccountName: external-secrets
      automountServiceAccountToken: true
      hostNetwork: false
      containers:
      - name: external-secrets
        securityContext:
          allowPrivilegeEscalation: false
          capabilities:
            drop:
            - ALL
          readOnlyRootFilesystem: true
          runAsNonRoot: true
          runAsUser: 1000
          seccompProfile:
            type: RuntimeDefault
        image: ghcr.io/external-secrets/external-secrets:{{ eso_version | default('v0.9.13') }}
        imagePullPolicy: IfNotPresent
        args:
        - --concurrent={{ eso_concurrent | default(1) }}
        - --metrics-addr=:{{ eso_metrics_port | default(8080) }}
        ports:
        - containerPort: {{ eso_metrics_port | default(8080) }}
          protocol: TCP
          name: metrics
        resources:
          requests:
            cpu: {{ eso_cpu_requests | default('100m') | quote }}
            memory: {{ eso_memory_requests | default('128Mi') | quote }}
          limits:
            cpu: {{ eso_cpu_limits | default('200m') | quote }}
            memory: {{ eso_memory_limits | default('256Mi') | quote }}
