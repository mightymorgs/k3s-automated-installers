{#
  External Secrets Operator ClusterSecretStore (Vault Backend)

  Variables:
    - vault_addr: Vault server URL (default: "http://vault.vault.svc.cluster.local:8200")
    - vault_path: Vault KV path (default: "secret")
    - vault_version: Vault KV version (default: "v2")
    - vault_auth_method: Vault auth method (default: "kubernetes")
    - vault_k8s_mount_path: Kubernetes auth mount path (default: "kubernetes")
    - vault_k8s_role: Vault Kubernetes auth role (default: "external-secrets")
    - vault_service_account: ESO service account name (default: "external-secrets")
    - vault_namespace: ESO namespace (default: "external-secrets")
    - secretstore_name: ClusterSecretStore name (default: "vault-backend")

  Usage:
    ansible.builtin.template:
      src: templates/secretstore.yaml.j2
      dest: /tmp/eso-secretstore.yaml
#}
---
apiVersion: external-secrets.io/v1
kind: ClusterSecretStore
metadata:
  name: {{ secretstore_name | default('vault-backend') }}
  labels:
    app.kubernetes.io/name: {{ secretstore_name | default('vault-backend') }}
    app.kubernetes.io/component: secrets-operator
    app.kubernetes.io/part-of: golden-master
spec:
  provider:
    vault:
      server: {{ vault_addr | quote }}
      path: {{ vault_path | default('secret') | quote }}
      version: {{ vault_version | default('v2') | quote }}
      auth:
        {{ vault_auth_method | default('kubernetes') }}:
          mountPath: {{ vault_k8s_mount_path | default('kubernetes') | quote }}
          role: {{ vault_k8s_role | default('external-secrets') | quote }}
          serviceAccountRef:
            name: {{ vault_service_account | default('external-secrets') | quote }}
            namespace: {{ vault_namespace | default('external-secrets') | quote }}
