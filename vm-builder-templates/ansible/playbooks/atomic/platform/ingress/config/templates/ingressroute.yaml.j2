# ansible/playbooks/atomic/platform/ingress/config/templates/ingressroute.yaml.j2
# Variables:
#   - app_name: Application name (REQUIRED)
#   - subdomain: Subdomain for the app (REQUIRED)
#   - service_name: K8s service name (REQUIRED)
#   - service_port: K8s service port (REQUIRED)
#   - app_namespace: K8s namespace (REQUIRED)
#   - domain: Full domain (subdomain.domain or subdomain.vm_hostname.tailnet) (REQUIRED)
#   - tls_secret: TLS certificate secret name (REQUIRED)
#   - paths: List of path configurations (default: [{'path': '/', 'path_type': 'Prefix'}])
#   - forwardauth_enabled: Whether to enable Authentik ForwardAuth middleware (default: false)
#
# Usage:
#   ansible.builtin.template:
#     src: ingressroute.yaml.j2
#     dest: /tmp/{{ app_name }}-ingressroute.yaml
#   vars:
#     app_name: "grafana"
#     subdomain: "grafana"
#     service_name: "grafana"
#     service_port: 3000
#     app_namespace: "observability"
#     domain: "grafana.demo.com"
#     tls_secret: "grafana-origin-cert"
#     forwardauth_enabled: true
---
apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: {{ app_name }}-ingressroute
  namespace: {{ app_namespace }}
  labels:
    app: {{ app_name }}
    managed-by: ansible
spec:
  entryPoints:
    - websecure
  routes:
    - match: Host(`{{ domain }}`)
      kind: Rule
      services:
        - name: {{ service_name }}
          port: {{ service_port }}
{% if forwardauth_enabled %}
      middlewares:
        - name: authentik-forwardauth
          namespace: authentik
{% endif %}
  tls:
    secretName: {{ tls_secret }}
