#cloud-config
# Generated by Terraform for VM: ${vm_name}
# Minimal bootstrap: Install runner + basics, let playbooks handle the rest
# Console credentials sourced from BWS: inventory/shared/secrets/console/*

hostname: ${vm_name}
manage_etc_hosts: true

users:
  - name: ${console_username}
    sudo: ALL=(ALL) NOPASSWD:ALL
    groups: ["adm", "sudo"]
    shell: /bin/bash
    lock_passwd: false
    ssh_authorized_keys:
%{ for key in ssh_authorized_keys ~}
      - ${key}
%{ endfor ~}

%{ if console_password != "" ~}
ssh_pwauth: true
chpasswd:
  users:
    - name: ${console_username}
      password: ${console_password}
      type: text
  expire: false
%{ else ~}
ssh_pwauth: false
%{ endif ~}

package_update: true
packages:
  - qemu-guest-agent
  - curl
  - gnupg
  - jq
  - unzip
  - python3
  - python3-pip
  - ansible
  - git

write_files:
  - path: /opt/bootstrap-runner.sh
    permissions: '0755'
    content: |
      #!/bin/bash
      # GitHub Actions Runner Bootstrap Script
      # Runs after VM is fully booted with networking
      set -euo pipefail
      exec > >(tee /var/log/bootstrap-runner.log) 2>&1

      echo "=== Starting runner bootstrap for ${vm_name} ==="
      date

      # Create runner user with sudo access
      useradd -m -s /bin/bash runner || true
      usermod -aG sudo runner || true
      echo "runner ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/runner
      chmod 0440 /etc/sudoers.d/runner

      cd /home/runner

      # Resolve latest runner version from GitHub API
      RUNNER_VERSION=$(curl -s https://api.github.com/repos/actions/runner/releases/latest | grep '"tag_name"' | sed 's/.*"v\(.*\)".*/\1/')
      if [ -z "$RUNNER_VERSION" ]; then
        RUNNER_VERSION="${github_runner_version}"
        echo "WARNING: Could not fetch latest runner version, falling back to $RUNNER_VERSION"
      fi
      echo "Using GitHub Actions runner version: $RUNNER_VERSION"
      curl -o actions-runner.tar.gz -L \
        "https://github.com/actions/runner/releases/download/v$${RUNNER_VERSION}/actions-runner-linux-x64-$${RUNNER_VERSION}.tar.gz"

      tar xzf actions-runner.tar.gz
      chown -R runner:runner /home/runner

      mkdir -p /home/runner/.ssh && chmod 700 /home/runner/.ssh

      # SSH deploy key (base64-encoded private key)
      PRIVATE_KEY_B64='${ssh_private_key_b64}'
      RUNNER_TOKEN='${runner_token}'

      if [ -n "$PRIVATE_KEY_B64" ]; then
        echo "$PRIVATE_KEY_B64" | base64 -d > /home/runner/.ssh/id_ed25519
        chmod 600 /home/runner/.ssh/id_ed25519
        ssh-keyscan github.com >> /home/runner/.ssh/known_hosts 2>/dev/null || true
        chmod 644 /home/runner/.ssh/known_hosts
        chown -R runner:runner /home/runner/.ssh
        echo "SSH deploy key configured"
      fi

      # Register runner if token was provided
      if [ -n "$RUNNER_TOKEN" ]; then
        echo "Registering GitHub Actions runner..."
        sudo -u runner ./config.sh \
          --url "https://github.com/${github_repo}" \
          --token "$RUNNER_TOKEN" \
          --name '${vm_name}' \
          --labels "self-hosted,libvirt,${vm_name}" \
          --unattended \
          --disableupdate

        echo "Installing runner service..."
        ./svc.sh install runner
        ./svc.sh start
        echo "GitHub Actions runner started"
      else
        echo "No runner token provided, skipping runner registration"
      fi

      echo "=== Runner bootstrap complete for ${vm_name} ==="
      date

  - path: /etc/systemd/system/bootstrap-runner.service
    permissions: '0644'
    content: |
      [Unit]
      Description=Bootstrap GitHub Actions Runner
      After=network-online.target
      Wants=network-online.target

      [Service]
      Type=oneshot
      ExecStart=/opt/bootstrap-runner.sh
      RemainAfterExit=yes
      StandardOutput=journal+console
      StandardError=journal+console

      [Install]
      WantedBy=multi-user.target

runcmd:
  - systemctl enable --now qemu-guest-agent
  - systemctl daemon-reload
  - systemctl enable bootstrap-runner.service
  - systemctl start bootstrap-runner.service
