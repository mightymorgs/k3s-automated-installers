#!/bin/bash
#
# Hypervisor Bootstrap Script
# Generated by vm-builder
#
# Hypervisor: {{ hypervisor_name }}
# Generated: {{ timestamp }}
#

set -euo pipefail

echo "========================================================================"
echo "Hypervisor Bootstrap: {{ hypervisor_name }}"
echo "========================================================================"
echo ""

# Color output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

log_info() {
    echo -e "${GREEN}✓${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}⚠${NC} $1"
}

log_error() {
    echo -e "${RED}✗${NC} $1"
}

# Check if running as root (will need sudo for some commands)
if [ "$EUID" -eq 0 ]; then
    SUDO=""
    # When run via sudo, SUDO_USER is the invoking user.
    # The GitHub Actions runner MUST NOT run as root.
    RUNNER_USER="${SUDO_USER:-$(logname 2>/dev/null || echo ubuntu)}"
    # Helper: run a command as the non-root runner user
    run_as_runner() { sudo -u "$RUNNER_USER" "$@"; }
else
    SUDO="sudo"
    RUNNER_USER="$(whoami)"
    run_as_runner() { "$@"; }
fi
log_info "Runner will be owned by user: $RUNNER_USER"

# Step 1: Install Tailscale
echo "------------------------------------------------------------------------"
echo "Step 1: Installing Tailscale"
echo "------------------------------------------------------------------------"

if command -v tailscale &> /dev/null; then
    log_info "Tailscale already installed: $(tailscale version)"
else
    log_info "Installing Tailscale..."
    curl -fsSL https://tailscale.com/install.sh | sh
fi

# Step 2: Join Tailscale network
echo ""
echo "------------------------------------------------------------------------"
echo "Step 2: Joining Tailscale Network"
echo "------------------------------------------------------------------------"

# Hypervisor name follows 4-segment convention:
# hv-{name}-{platform}-{location}
# Example: hv-auros15g-libvirt-office
HYPERVISOR_NAME="{{ hypervisor_name }}"
SHORT_NAME="{{ short_name }}"

# Parse name components (for logging only — device cleanup and auth key
# creation already happened server-side during script generation)
PLATFORM="{{ platform }}"
LOCATION="{{ location }}"

log_info "Parsed name components:"
log_info "  Name: $SHORT_NAME, Platform: $PLATFORM, Location: $LOCATION"

# Derive tags for logging (actual tags were set server-side when creating the auth key)
TAILSCALE_TAGS='["tag:hypervisor", "tag:vm-host", "tag:service-ssh", "tag:hv-{{ short_name }}"]'
log_info "Expected Tailscale tags: $TAILSCALE_TAGS"

# Pre-generated single-use auth key (created server-side, device cleanup already done)
AUTH_KEY="{{ tailscale_auth_key }}"

# Join Tailscale (with --reset to override existing config, --ssh to enable SSH access)
# Tags are set on the auth key server-side — ACL rules match on tags, not hostname.
# hv-{name}-{platform}-{location} is already short enough — no MagicDNS rename needed.
$SUDO tailscale up --authkey="$AUTH_KEY" --hostname="{{ hypervisor_name }}" --ssh --reset
log_info "Joined Tailscale network as {{ hypervisor_name }}"

TAILSCALE_IP=$(tailscale ip -4)
log_info "Tailscale IP: $TAILSCALE_IP"

# Step 3: Install GitHub Actions Runner
echo ""
echo "------------------------------------------------------------------------"
echo "Step 3: Installing GitHub Actions Runner"
echo "------------------------------------------------------------------------"

# Resolve latest runner version from GitHub API
RUNNER_VERSION=$(curl -s https://api.github.com/repos/actions/runner/releases/latest | grep '"tag_name"' | sed 's/.*"v\(.*\)".*/\1/')
if [ -z "$RUNNER_VERSION" ]; then
    RUNNER_VERSION="{{ github_runner_version | default('2.332.0') }}"
    log_warn "Could not fetch latest runner version, falling back to $RUNNER_VERSION"
fi
log_info "Using GitHub Actions runner version: $RUNNER_VERSION"
RUNNER_DIR="/opt/github-runner"

if [ -d "$RUNNER_DIR" ]; then
    log_warn "Runner directory already exists: $RUNNER_DIR"
    if [ -f "$RUNNER_DIR/.runner" ]; then
        log_info "Runner already configured, uninstalling service first..."
        cd "$RUNNER_DIR"
        $SUDO ./svc.sh stop 2>/dev/null || true
        $SUDO ./svc.sh uninstall 2>/dev/null || true
        log_info "Service uninstalled, cleaning up directory..."
        cd /
    fi
    $SUDO rm -rf "$RUNNER_DIR"
    log_info "Runner directory cleaned up"
fi

# Clean up any leftover systemd service files
SERVICE_FILE="/etc/systemd/system/actions.runner.{{ github_repo | replace('/', '-') }}.{{ hypervisor_name }}.service"
if [ -f "$SERVICE_FILE" ]; then
    log_warn "Removing leftover service file: $SERVICE_FILE"
    $SUDO rm -f "$SERVICE_FILE"
    $SUDO systemctl daemon-reload
fi

if [ ! -d "$RUNNER_DIR" ]; then
    log_info "Creating runner directory: $RUNNER_DIR"
    $SUDO mkdir -p "$RUNNER_DIR"
    $SUDO chown "${RUNNER_USER}:${RUNNER_USER}" "$RUNNER_DIR"

    cd "$RUNNER_DIR"

    # Download runner (as the runner user to avoid root-owned files)
    log_info "Downloading GitHub Actions Runner v${RUNNER_VERSION}..."
    run_as_runner curl -o actions-runner.tar.gz -L \
        "https://github.com/actions/runner/releases/download/v${RUNNER_VERSION}/actions-runner-linux-x64-${RUNNER_VERSION}.tar.gz"

    # Extract
    log_info "Extracting runner..."
    run_as_runner tar xzf actions-runner.tar.gz
    rm actions-runner.tar.gz

    # Pre-generated 1-hour registration token (created server-side, stale runner cleanup already done)
    REG_TOKEN="{{ github_runner_reg_token }}"
    GITHUB_REPO="{{ github_repo }}"
    RUNNER_NAME="{{ hypervisor_name }}"

    log_info "Configuring runner as $RUNNER_USER..."
    # Labels include: hypervisor (type), short name, full name, platform, location
    # config.sh MUST NOT run as root — use run_as_runner to drop privileges
    run_as_runner ./config.sh \
        --url "https://github.com/${GITHUB_REPO}" \
        --token "$REG_TOKEN" \
        --name "$RUNNER_NAME" \
        --labels "hypervisor,{{ short_name }},{{ hypervisor_name }},{{ platform }},{{ location }}" \
        --work "_work" \
        --unattended

    # Install as service (svc.sh install MUST run as root, it creates systemd unit)
    log_info "Installing runner as systemd service..."
    $SUDO ./svc.sh install "$RUNNER_USER"
    $SUDO ./svc.sh start

    log_info "GitHub Actions runner installed and started"
fi

# Step 4: Trigger Phase 0 workflow via vm-builder API
echo ""
echo "------------------------------------------------------------------------"
echo "Step 4: Triggering Phase 0 (QEMU/Libvirt Setup)"
echo "------------------------------------------------------------------------"
{% if vm_builder_api_url %}
# The vm-builder API triggers workflow_dispatch server-side.
# The PAT never leaves the server — only ephemeral tokens are used.
PHASE0_URL="{{ vm_builder_api_url }}/api/v1/hypervisor/phase0"
PHASE0_PAYLOAD='{"hypervisor_name":"{{ hypervisor_name }}"}'

log_info "Triggering Phase 0 via vm-builder API..."
log_info "  URL: $PHASE0_URL"

PHASE0_RESP=$(curl -sS -w "\n%{http_code}" \
  -X POST "$PHASE0_URL" \
  -H "Content-Type: application/json" \
  -d "$PHASE0_PAYLOAD" 2>&1) || true

PHASE0_BODY=$(echo "$PHASE0_RESP" | sed '$d')
PHASE0_CODE=$(echo "$PHASE0_RESP" | tail -n1)

if [ "$PHASE0_CODE" = "200" ]; then
    log_info "Phase 0 workflow triggered successfully"
    echo "$PHASE0_BODY" | jq -r '.' 2>/dev/null || echo "$PHASE0_BODY"
else
    log_warn "Phase 0 trigger returned HTTP $PHASE0_CODE (may need manual trigger)"
    log_warn "Response: $PHASE0_BODY"
    echo ""
    echo "To trigger manually:"
    echo "  curl -X POST $PHASE0_URL -H 'Content-Type: application/json' -d '$PHASE0_PAYLOAD'"
fi
{% else %}
log_warn "No vm-builder API URL configured — Phase 0 must be triggered manually"
echo ""
echo "To trigger Phase 0 manually:"
echo "  1. Via GitHub Actions: https://github.com/{{ github_repo }}/actions/workflows/install-phase0-hypervisor-setup.yml"
echo "     Input: hypervisor_name = {{ hypervisor_name }}"
echo "  2. Via vm-builder API: POST /api/v1/hypervisor/phase0"
echo '     Body: {"hypervisor_name":"{{ hypervisor_name }}"}'
{% endif %}

echo ""
echo "========================================================================"
echo "Bootstrap Complete!"
echo "========================================================================"
echo ""
log_info "Hypervisor: {{ hypervisor_name }}"
log_info "Tailscale IP: $TAILSCALE_IP"
log_info "GitHub Runner: {{ hypervisor_name }} registered and running"
{% if vm_builder_api_url %}
log_info "Phase 0: Triggered via {{ vm_builder_api_url }}"
{% else %}
log_warn "Phase 0: Not auto-triggered (no API URL configured)"
{% endif %}
echo ""
echo "Verify:"
echo "  1. Runner: https://github.com/{{ github_repo }}/settings/actions/runners"
echo "  2. Tailscale: https://login.tailscale.com/admin/machines"
echo "  3. Phase 0: https://github.com/{{ github_repo }}/actions/workflows/install-phase0-hypervisor-setup.yml"
echo ""
